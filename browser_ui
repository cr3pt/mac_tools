
<!DOCTYPE html>
<html>
<head>
  <title>Noriben SOC Platform v2</title>
  <meta charset="utf-8">
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script src="https://unpkg.com/hyperscript.org@0.9.12"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body class="bg-gradient-to-br from-gray-900 to-gray-800 text-gray-100 min-h-screen">
  <!-- Header with notifications -->
  <nav class="bg-gray-800/95 backdrop-blur-md p-4 shadow-2xl border-b border-gray-700/50 fixed w-full z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <div class="flex items-center space-x-4">
        <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-purple-600 rounded-xl flex items-center justify-center">
          <span class="text-white font-bold">SOC</span>
        </div>
        <h1 class="text-2xl font-black tracking-tight">Noriben SOC v2</h1>
      </div>

      <!-- Live status indicator -->
      <div id="ws-status" class="flex items-center space-x-2 text-sm bg-gray-700 px-3 py-1 rounded-full">
        <div class="w-2 h-2 rounded-full bg-red-400" id="ws-dot"></div>
        <span>Disconnected</span>
      </div>

      <!-- Auth -->
      <div id="auth-section" class="space-x-2">
        <button _="on click trigger toggleLogin" class="bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 px-6 py-2 rounded-xl font-medium shadow-lg transition-all">Login</button>
      </div>
      <div id="user-section" class="hidden flex items-center space-x-4">
        <span id="user-info" class="bg-gray-700 px-3 py-1 rounded-full text-sm font-medium"></span>
        <button id="logout-btn" _="on click post '/auth/logout' then trigger clearAuth" 
                class="bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-800 px-4 py-2 rounded-xl font-medium shadow-lg transition-all">Logout</button>
      </div>
    </div>
  </nav>

  <!-- Login Modal -->
  <div id="login-modal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4" 
       _="on htmx:afterRequest from #login-form if response.status == 200 trigger hideLogin else add .animate-pulse to #error-login">
    <div class="bg-gray-800/95 backdrop-blur-md p-10 rounded-2xl max-w-md w-full border border-gray-600 shadow-2xl">
      <h2 class="text-2xl font-black mb-6 text-center bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">Login</h2>
      <form id="login-form" hx-post="/auth/login" hx-target="#login-response" class="space-y-4">
        <div>
          <input id="login-username" name="username" placeholder="tier1 / tier2 / admin" 
                 class="w-full p-4 bg-gray-900/50 border border-gray-600 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" required>
        </div>
        <div>
          <input name="password" type="password" placeholder="tier1pass / tier2pass / adminpass" 
                 class="w-full p-4 bg-gray-900/50 border border-gray-600 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" required>
        </div>
        <button type="submit" class="w-full bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 p-4 rounded-xl font-bold text-lg shadow-xl transition-all transform hover:scale-105">
          🔐 Sign In
        </button>
      </form>
      <div id="login-response" class="mt-6 p-4 rounded-xl hidden"></div>
      <div id="error-login" class="text-red-400 mt-4 text-center font-medium hidden">Invalid credentials</div>
    </div>
  </div>

  <!-- Main Content -->
  <main id="main-content" class="pt-20 pb-10 max-w-7xl mx-auto px-6">

    <!-- Live Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
      <div class="bg-gradient-to-br from-blue-600/20 to-blue-700/20 backdrop-blur-md p-8 rounded-2xl border border-blue-500/30 group hover:shadow-2xl transition-all">
        <div class="text-4xl font-black text-blue-400 mb-2" id="sessions-count">0</div>
        <div class="text-blue-200 font-medium">Sessions</div>
      </div>
      <div class="bg-gradient-to-br from-yellow-600/20 to-yellow-700/20 backdrop-blur-md p-8 rounded-2xl border border-yellow-500/30 group hover:shadow-2xl transition-all">
        <div class="text-4xl font-black text-yellow-400 mb-2" id="jobs-queued">0</div>
        <div class="text-yellow-200 font-medium">Jobs Live</div>
      </div>
      <div class="bg-gradient-to-br from-red-600/20 to-red-700/20 backdrop-blur-md p-8 rounded-2xl border border-red-500/30 group hover:shadow-2xl transition-all">
        <div class="text-4xl font-black text-red-400 mb-2" id="high-severity">0</div>
        <div class="text-red-200 font-medium">High Alerts</div>
      </div>
      <div class="bg-gradient-to-br from-green-600/20 to-green-700/20 backdrop-blur-md p-8 rounded-2xl border border-green-500/30 group hover:shadow-2xl transition-all">
        <div class="text-3xl font-black text-green-400 mb-2" id="ws-jobs-count">0</div>
        <div class="text-green-200 font-medium">WS Updates</div>
      </div>
    </div>

    <!-- Multi-file Drag & Drop Upload -->
    <div class="bg-gray-800/50 backdrop-blur-md p-10 rounded-3xl mb-12 border-2 border-dashed border-gray-600 hover:border-blue-500 transition-all group">
      <div class="text-center">
        <div class="w-24 h-24 mx-auto mb-6 bg-gradient-to-br from-purple-500 to-pink-500 rounded-3xl flex items-center justify-center shadow-2xl mx-auto group-hover:scale-110 transition-transform">
          <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-black mb-2 bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">Drop Files Here</h2>
        <p class="text-gray-400 mb-8 max-w-md mx-auto">Upload multiple .exe, .evtx, .ps1 files for analysis (Max 50MB)</p>

        <!-- Drag zone -->
        <div id="drop-zone" class="border-4 border-dashed border-gray-600 rounded-3xl p-12 hover:border-blue-500 hover:bg-blue-500/10 transition-all cursor-pointer min-h-[200px] flex flex-col items-center justify-center"
             _="on dragover prevent default on dragenter add .bg-blue-500/20 on dragleave remove .bg-blue-500/20 on drop prevent default then js(getFiles)"
             class="group-hover:scale-[1.02] transition-transform">
          <input type="file" id="file-input" name="files" multiple accept=".exe,.evtx,.ps1,.dll,.scr" class="hidden">
          <label for="file-input" class="cursor-pointer w-full h-full flex flex-col items-center justify-center">
            <svg class="w-16 h-16 text-gray-400 mb-4 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
            <span class="font-semibold text-lg">Click or drag files here</span>
            <span class="text-sm text-gray-500 mt-1">.exe .evtx .ps1 .dll .scr</span>
          </label>
        </div>

        <div id="upload-progress" class="mt-6 hidden space-y-2">
          <div class="w-full bg-gray-700 rounded-full h-3">
            <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-3 rounded-full transition-all" style="width: 0%" id="progress-bar"></div>
          </div>
          <div id="upload-status" class="text-sm text-center text-blue-400 font-mono"></div>
        </div>
      </div>

      <div id="upload-response" class="mt-8 p-6 bg-green-900/50 rounded-2xl border border-green-500/30 hidden"></div>
    </div>

    <!-- Live Jobs Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 mb-12">
      <div class="bg-gray-800/70 backdrop-blur-md p-8 rounded-3xl border border-gray-600 col-span-full">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-black">⏳ Live Jobs</h2>
          <button hx-get="/jobs" hx-target="#jobs-container" hx-swap="innerHTML"
                  class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-xl font-medium transition-all">Refresh</button>
        </div>
        <div id="jobs-container" class="space-y-4">
          <!-- Dynamic jobs cards -->
        </div>
      </div>
    </div>

    <!-- Sessions Table with Export -->
    <div class="bg-gray-800/70 backdrop-blur-md p-8 rounded-3xl border border-gray-600">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-black">📊 Analysis Sessions</h2>
        <div class="space-x-3">
          <button hx-get="/sessions" hx-target="#sessions-table" hx-swap="innerHTML"
                  class="bg-emerald-600 hover:bg-emerald-700 px-4 py-2 rounded-xl font-medium transition-all">Refresh</button>
          <button onclick="exportCSV()" class="bg-yellow-600 hover:bg-yellow-700 px-4 py-2 rounded-xl font-medium transition-all">📄 CSV</button>
          <button onclick="exportPDF()" class="bg-purple-600 hover:bg-purple-700 px-4 py-2 rounded-xl font-medium transition-all">📄 PDF</button>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table id="sessions-table" class="w-full text-sm">
          <thead class="sticky top-0 bg-gray-900/50 backdrop-blur-md">
            <tr>
              <th class="p-4 text-left font-bold border-b border-gray-700">Session ID</th>
              <th class="p-4 text-left font-bold border-b border-gray-700">Sample</th>
              <th class="p-4 text-left font-bold border-b border-gray-700">Severity</th>
              <th class="p-4 text-left font-bold border-b border-gray-700">Confidence</th>
              <th class="p-4 text-left font-bold border-b border-gray-700">Status</th>
              <th class="p-4 text-left font-bold border-b border-gray-700">SHA256</th>
              <th class="p-4 text-left font-bold border-b border-gray-700">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <!-- Dynamic content -->
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    // WebSocket for live updates
    let ws = null;
    function connectWS() {
      ws = new WebSocket('ws://' + location.host + '/ws');
      ws.onopen = () => {
        document.getElementById('ws-dot').className = 'w-2 h-2 rounded-full bg-green-400 animate-pulse';
        document.getElementById('ws-status').innerHTML = '<span>🟢 Live</span>';
      };
      ws.onmessage = (event) => {
        const data = JSON.parse(event.data);
        updateLiveStats(data);
      };
      ws.onclose = () => {
        document.getElementById('ws-dot').className = 'w-2 h-2 rounded-full bg-red-400';
        document.getElementById('ws-status').innerHTML = '<span>🔴 Reconnecting...</span>';
        setTimeout(connectWS, 3000);
      };
    }

    // Multi-file drag & drop
    function getFiles(e) {
      const files = Array.from(e.dataTransfer?.files || e.target.files);
      const dt = new DataFormData();
      files.forEach((file, i) => dt.append(`file${i}`, file));
      htmx.ajax('POST', '/upload', {requestConfig: {values: dt}});
    }

    // Live stats update
    function updateLiveStats(data) {
      document.getElementById('jobs-queued').textContent = data.jobs_queued || 0;
      document.getElementById('high-severity').textContent = data.high_severity || 0;
      document.getElementById('ws-jobs-count').textContent++;
    }

    // CSV Export
    function exportCSV() {
      htmx.ajax('GET', '/sessions?format=csv').then((resp) => {
        const blob = new Blob([resp], {type: 'text/csv'});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'noriben-sessions.csv';
        a.click();
      });
    }

    // PDF Export  
    function exportPDF() {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      doc.text('Noriben SOC Sessions Report', 20, 20);
      // Add table from sessions data
      doc.save('noriben-sessions.pdf');
    }

    // Auth handlers
    document.body.addEventListener('htmx:afterRequest', (e) => {
      if (e.detail.target.id === 'login-response' && e.detail.xhr.status === 200) {
        const data = JSON.parse(e.detail.xhr.response);
        localStorage.setItem('noriben_token', data.token);
        location.reload(); // Refresh for full UI
      }
    });

    // Init
    connectWS();
    const savedToken = localStorage.getItem('noriben_token');
    if (savedToken) {
      document.getElementById('user-section').classList.remove('hidden');
      document.getElementById('main-content').classList.remove('hidden');
    }
  </script>
</body>
</html>

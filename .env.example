# Example configuration for Noriben SOC
NORIBEN_ENV=development
DATABASE_URL=postgresql://noriben:noriben123@localhost/noriben
CELERY_BROKER=redis://localhost:6379/0
LOG_LEVEL=INFO
LOG_JSON=False
UPLOAD_DIR=/tmp/noriben_uploads
ADMIN_USER=admin
# Set a strong password in production
ADMIN_PASS=changeme
# Optional: explicit Redis URL for token store (fallback uses CELERY_BROKER)
REDIS_URL=redis://localhost:6379/1
# VIRUSTOTAL_API_KEY=your_api_key
# OTX_API_KEY=your_api_key
